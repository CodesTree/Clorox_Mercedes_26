# Copy to .env and fill in. Never commit real secrets.

# --- API / scraper ---
CORS_ORIGINS=http://localhost:5173
SCRAPER_USER_AGENT=AssetIQResearchBot/0.1 (+contact)
SCRAPER_RATE_LIMIT_SECONDS=4.0

# --- Booking agent: Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Booking agent: Gemini (reply intent classification) ---
GEMINI_API_KEY=

# --- Booking agent: Google Calendar ---
# Service account (path to JSON file or inline JSON). Used for BOTH availability
# (free/busy) reads and event creation. Share the target calendar with the SA's
# client_email ("Make changes to events"). GET /booking/diagnostics prints it.
GOOGLE_CALENDAR_CREDENTIALS_JSON=./secrets/google_sa.json
# The calendar to book on. Use the real address (e.g. you@gmail.com), NOT "primary":
# with a service account "primary" is the SA's own hidden calendar.
GOOGLE_CALENDAR_ID=you@gmail.com
GOOGLE_CALENDAR_TIMEZONE=Asia/Kuala_Lumpur
# GOOGLE_CALENDAR_KEY is deprecated/unused (an API key can't read private calendars).
