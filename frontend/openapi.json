      "FaultsOut": {
        "properties": {
          "faults": {
            "items": {
              "$ref": "#/components/schemas/FaultOut"
            },
            "type": "array",
            "title": "Faults"
          }
        },
        "type": "object",
        "required": [
          "faults"
