            "title": "Profile Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "workshop": {
            "type": "string",
            "title": "Workshop"
          },
          "car_model": {
            "type": "string",
            "title": "Car Model"
          },
          "purpose": {
            "type": "string",
            "title": "Purpose"
          },
          "date": {
            "type": "string",
            "title": "Date"
          },
          "time": {
            "type": "string",
            "title": "Time"
          }
        },
        "type": "object",
        "required": [
          "profile_id",
          "name",
          "workshop",
          "car_model",
          "purpose",
          "date",
          "time"
        ],
        "title": "BookingIn"
      },
      "BookingOut": {
        "properties": {
          "booking_id": {
            "type": "integer",
            "title": "Booking Id"
