              "mudah",
              "carlist"
            ],
            "title": "Source"
          },
          "listing_url": {
            "type": "string",
            "title": "Listing Url"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "variant": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Variant"
