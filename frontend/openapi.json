            "title": "Points"
          }
        },
        "type": "object",
        "required": [
          "points"
        ],
        "title": "DepreciationOut"
      },
      "DepreciationPoint": {
        "properties": {
          "year": {
            "type": "integer",
            "title": "Year"
          },
          "value_rm": {
            "type": "integer",
            "title": "Value Rm"
          },
          "retained_pct": {
            "type": "number",
            "title": "Retained Pct"
