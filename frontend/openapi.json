      "ObdSnapshotOut": {
        "properties": {
          "rpm": {
            "type": "integer",
            "title": "Rpm"
          },
          "coolant_c": {
            "type": "number",
            "title": "Coolant C"
          },
          "battery_v": {
            "type": "number",
            "title": "Battery V"
          },
          "health": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Health"
          },
          "odo_km": {
            "type": "integer",
            "title": "Odo Km"
          },
          "simulated": {
            "type": "boolean",
            "const": true,
            "title": "Simulated",
            "default": true
          },
          "ts": {
            "type": "string",
            "format": "date-time",
            "title": "Ts"
          }
        },
        "type": "object",
        "required": [
          "rpm",
          "coolant_c",
          "battery_v",
          "health",
          "odo_km",
          "ts"
        ],
        "title": "ObdSnapshotOut"
