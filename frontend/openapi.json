{
  "openapi": "3.1.0",
  "info": {
    "title": "AssetIQ API",
    "version": "0.1.0"
  },
  "paths": {
    "/predict": {
      "post": {
        "tags": [
          "valuation"
        ],
        "summary": "Predict",
        "operationId": "predict_predict_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VehicleProfileIn"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PredictOut"
