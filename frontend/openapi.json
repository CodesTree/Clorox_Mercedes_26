          "year": {
            "type": "integer",
            "title": "Year"
          },
          "price_rm": {
            "type": "integer",
            "title": "Price Rm"
          },
          "mileage": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
